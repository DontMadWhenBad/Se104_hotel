{
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": "frontend",
  "public": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(?!index\\.html).*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ],
  "github": {
    "silent": true
  }
}
